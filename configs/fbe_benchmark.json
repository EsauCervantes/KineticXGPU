{
  "device": "cuda",
  "dtype": "float64",
  "save": true,
  "results_dir": "results/runs/conservative",
  "run_name_prefix": "hybrid_saved",

  "cosmology": {
    "use_torch_tables": true
  },

  "physics": {
    "a0": 1.0,
    "af": 1e5,
    "m_chi": 0.5,
    "m_h": 125.0,
    "v_h": 246.0,
    "lambda_portal": 1.08e-11,
    "m_condensate": 1.8,
    "gamma_condensate": 1.0e-21,
    "n_condensate_initial": 0.02,
    "multiplicity_condensate": 2.0,
    "xi_inf": 1.0e-4
  },

  "grid": {
    "q_min": 0.5,
    "q_max": 500000.0,
    "N": 200
  },

  "collision": {
    "_comment": "below can be dense or conservative",
    "operator": "conservative",
    "lambda_self_values": [8.0e-5],
    "Ng": 14,
    "batch_size": 16
  },

  "hybrid": {
    "n_windows": 400,
    "gamma_over_H_on": 0.12,
    "gamma_check_every_far": 50,
    "gamma_check_every_mid": 20,
    "gamma_check_every_near": 5,
    "rk4_steps_per_window": 1,
    "rk4_store_every_steps": 20
  },

  "heun": {
    "du_init": 1e-3,
    "du_min": 5.0e-7,
    "du_max": 0.15,
    "rtol": 1.0e-3,
    "atol": 1.0e-12,
    "safety": 0.95,
    "store_every_accepted": 1,
    "print_every_accepted": 20
  },

  "stability": {
    "clip_negative": true,
    "clip_tol": 0.0
  },

  "cbe": {
    "af": 1e5,
    "method": "Radau",
    "rtol": 1.0e-6,
    "atol": 1.0e-9,
    "max_step_u": 0.001,
    "condensate_n_eval": 4000,
    "condensate_zero_rel": 1.0e-14
  }
}
